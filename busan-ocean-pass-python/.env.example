PORT=3000
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_DAYS=7
DB_PATH=./data/busan-ocean-pass.sqlite
GEMINI_API_KEY=your_gemini_api_key_here

# 혼잡도 설정
CONGESTION_WINDOW_MINUTES=60
CONGESTION_HIGH_THRESHOLD=20
CONGESTION_MID_THRESHOLD=8

# GPS 인증 반경 (미터)
GPS_VERIFY_RADIUS_METERS=200

# 마스터 어드민
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=
