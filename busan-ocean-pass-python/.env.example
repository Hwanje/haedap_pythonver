PORT=3000
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_DAYS=7

# PostgreSQL (Neon) 연결 문자열 — 서버가 꺼져도 데이터가 유지됩니다.
# Neon 대시보드의 connection string 을 그대로 붙여넣으세요 (pooler 엔드포인트 권장).
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/dbname?sslmode=require

GEMINI_API_KEY=your_gemini_api_key_here
# 사용할 Gemini 모델 (미지정 시 gemini-2.5-flash). 예: gemini-2.5-flash, gemini-2.0-flash, gemini-flash-latest
GEMINI_MODEL=gemini-2.5-flash

# 혼잡도 설정
CONGESTION_WINDOW_MINUTES=60
CONGESTION_HIGH_THRESHOLD=20
CONGESTION_MID_THRESHOLD=8

# GPS 인증 반경 (미터)
GPS_VERIFY_RADIUS_METERS=200

# 마스터 어드민
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=
