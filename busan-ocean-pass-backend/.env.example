# =============================================
# 부산오션패스 백엔드 환경 변수 설정
# 이 파일을 복사해 .env 로 이름 바꾼 후 값을 채워주세요.
# Replit 사용 시: Secrets 탭에서 각 변수를 등록하세요.
# =============================================

# 서버 포트 (Replit은 내부 3000 → 외부 80 자동 매핑)
PORT=3000

# JWT 비밀 키 — 충분히 길고 복잡한 문자열 사용 (최소 32자 권장)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT 만료 시간
JWT_EXPIRES_IN=7d

# =============================================
# 혼잡도 계산 파라미터
# =============================================

# 혼잡도를 계산할 시간 윈도우 (분 단위)
CONGESTION_WINDOW_MINUTES=60

# 스탬프 배율: 여유(low) / 보통(mid) / 혼잡(high)
STAMP_LOW_MULTIPLIER=2.0
STAMP_MID_MULTIPLIER=1.5
STAMP_HIGH_MULTIPLIER=1.0

# 혼잡 임계값: 이 값 이상이면 혼잡(high)
CONGESTION_HIGH_THRESHOLD=20

# 보통 임계값: 이 값 이상이면 보통(mid)
CONGESTION_MID_THRESHOLD=8

# =============================================
# GPS 검증 파라미터
# =============================================

# 스탬프 인증 허용 반경 (미터 단위)
GPS_VERIFY_RADIUS_METERS=200

# =============================================
# SQLite 데이터베이스 경로
# =============================================
DB_PATH=./data/busan-ocean-pass.sqlite

# =============================================
# 기타 설정
# =============================================

# 24시간 재인증 차단 (밀리초 단위, 86400000 = 24h)
STAMP_COOLDOWN_MS=86400000

# 리뷰 최소 글자 수 (보너스 스탬프 조건)
REVIEW_MIN_LENGTH=50

# 위키 제보 최소 글자 수
WIKI_MIN_LENGTH=20
