# =============================================
# 부산오션패스 .gitignore
# =============================================

# 패키지 의존성 (npm install로 복원 가능)
node_modules/

# 환경 변수 (민감 정보 포함 — 절대 커밋 금지!)
.env
.env.local
.env.production

# SQLite 데이터베이스 파일 (런타임 데이터)
data/*.sqlite
data/*.sqlite-wal
data/*.sqlite-shm
data/*.db

# 로그 파일
*.log
logs/
npm-debug.log*

# OS 생성 파일
.DS_Store
Thumbs.db

# 에디터 설정
.vscode/
.idea/
*.swp
*.swo

# Replit 내부 파일 (선택적 — 팀원이 다른 환경 사용 시 제외)
.upm/
.config/

# 빌드 산출물 (native addon 등)
build/
dist/
*.node
